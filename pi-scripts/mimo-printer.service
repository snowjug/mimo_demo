[Unit]
Description=Mimo Pi Printer Service
After=network-online.target cups.service tailscaled.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/pi/mimo-printer/pi-scripts
Environment=PI_BIND_HOST=0.0.0.0
Environment=PI_BIND_PORT=8000
ExecStart=/home/pi/mimo-printer/.venv/bin/uvicorn printer_server:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=2
User=pi

[Install]
WantedBy=multi-user.target